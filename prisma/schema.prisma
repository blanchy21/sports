generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Phase 1 — Custodial onboarding models
// ============================================================================

// Google OAuth users with server-side custodial Hive keys
model CustodialUser {
  id              String    @id @default(uuid())
  email           String    @unique
  googleId        String    @unique @map("google_id")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  hiveUsername    String?   @unique @map("hive_username")
  encryptedKeys    String?   @map("encrypted_keys") // AES-256-GCM encrypted JSON of Hive keys
  encryptionIv     String?   @map("encryption_iv")
  encryptionSalt   String?   @map("encryption_salt") // Per-user random salt for key derivation
  keysDownloaded       Boolean   @default(false) @map("keys_downloaded")
  keysDownloadedAt     DateTime? @map("keys_downloaded_at")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  isGraduated          Boolean   @default(false) @map("is_graduated")
  rcDelegatedAt        DateTime? @map("rc_delegated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accountTokens   AccountToken[]

  @@index([isGraduated])
  @@map("custodial_users")
}

// Tracks Hive account token claims (one free account per user)
model AccountToken {
  id            String             @id @default(uuid())
  hiveUsername  String             @map("hive_username")
  status        AccountTokenStatus @default(PENDING)
  claimedAt     DateTime?          @map("claimed_at")
  errorMessage  String?            @map("error_message")
  createdAt     DateTime           @default(now()) @map("created_at")

  userId        String             @map("user_id")
  user          CustodialUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("account_tokens")
}

enum AccountTokenStatus {
  PENDING
  CLAIMED
  FAILED
}

// Key-value store for analytics cache + cron idempotency
model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String   @unique @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("analytics_events")
}

// ============================================================================
// Phase 2 — Application models
// ============================================================================

// User profiles (both soft/custodial and Hive users)
model Profile {
  id              String    @id @default(uuid())
  username        String    @unique
  displayName     String    @map("display_name")
  bio             String?
  avatarUrl       String?   @map("avatar_url")
  isHiveUser      Boolean   @default(false) @map("is_hive_user")
  hiveUsername     String?   @map("hive_username")
  followerCount   Int       @default(0) @map("follower_count")
  followingCount  Int       @default(0) @map("following_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastActiveAt    DateTime? @map("last_active_at")

  // Relations
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  followsGiven    Follow[]        @relation("FollowsGiven")
  followsReceived Follow[]        @relation("FollowsReceived")
  communityMemberships CommunityMember[]
  notifications   Notification[]
  bookmarks       Bookmark[]
  sportsbites     Sportsbite[] @relation("ProfileSportsbites")

  @@index([isHiveUser])
  @@index([lastActiveAt])
  @@map("profiles")
}

// Soft posts (stored locally, may be published to Hive)
model Post {
  id                String    @id @default(uuid())
  authorId          String    @map("author_id")
  author            Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorUsername     String    @map("author_username")
  authorDisplayName String?   @map("author_display_name")
  authorAvatar      String?   @map("author_avatar")
  title             String
  content           String
  excerpt           String?
  permlink          String    @unique
  tags              String[]  @default([])
  sportCategory     String?   @map("sport_category")
  featuredImage     String?   @map("featured_image")
  communityId       String?   @map("community_id")
  communitySlug     String?   @map("community_slug")
  communityName     String?   @map("community_name")
  isPublishedToHive Boolean   @default(false) @map("is_published_to_hive")
  hivePermlink      String?   @map("hive_permlink")
  viewCount         Int       @default(0) @map("view_count")
  likeCount         Int       @default(0) @map("like_count")
  commentCount      Int       @default(0) @map("comment_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  comments          Comment[]

  @@index([authorId])
  @@index([authorUsername])
  @@index([communityId])
  @@index([createdAt])
  @@map("soft_posts")
}

// Sportsbites (short-form content)
model Sportsbite {
  id                String    @id @default(uuid())
  authorId          String    @map("author_id")
  author            Profile   @relation("ProfileSportsbites", fields: [authorId], references: [id], onDelete: Cascade)
  authorUsername     String    @map("author_username")
  authorDisplayName String?   @map("author_display_name")
  authorAvatar      String?   @map("author_avatar")
  body              String
  sportCategory     String?   @map("sport_category")
  images            String[]  @default([])
  gifs              String[]  @default([])
  matchThreadId     String?   @map("match_thread_id")
  poll              Json?
  likeCount         Int       @default(0) @map("like_count")
  commentCount      Int       @default(0) @map("comment_count")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([authorUsername])
  @@index([matchThreadId])
  @@index([isDeleted, matchThreadId, createdAt])
  @@map("soft_sportsbites")
}

// Comments on soft posts
model Comment {
  id                String    @id @default(uuid())
  postId            String    @map("post_id")
  post              Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  postPermlink      String    @map("post_permlink")
  authorId          String    @map("author_id")
  author            Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorUsername     String    @map("author_username")
  authorDisplayName String?   @map("author_display_name")
  authorAvatar      String?   @map("author_avatar")
  isHiveUser        Boolean   @default(false) @map("is_hive_user")
  parentCommentId   String?   @map("parent_comment_id")
  body              String
  likeCount         Int       @default(0) @map("like_count")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([postId])
  @@index([postPermlink])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([isDeleted, postId, createdAt])
  @@map("soft_comments")
}

// Likes on posts and comments
model Like {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String   @map("target_type") // 'post' | 'comment'
  targetId   String   @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("soft_likes")
}

// Follow relationships
model Follow {
  id               String   @id @default(uuid())
  followerId       String   @map("follower_id")
  follower         Profile  @relation("FollowsGiven", fields: [followerId], references: [id], onDelete: Cascade)
  followerUsername  String   @map("follower_username")
  followedId       String   @map("followed_id")
  followed         Profile  @relation("FollowsReceived", fields: [followedId], references: [id], onDelete: Cascade)
  followedUsername  String   @map("followed_username")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([followerId, followedId])
  @@index([followedId])
  @@index([followerId])
  @@map("soft_follows")
}

// Sportsbite emoji reactions
model Reaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  sportsbiteId  String   @map("sportsbite_id")
  emoji         String   // 'fire' | 'shocked' | 'laughing' | 'angry' | 'eyes' | 'thumbs_down'
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, sportsbiteId])
  @@index([sportsbiteId])
  @@map("sportsbite_reactions")
}

// Poll votes on sportsbites
model PollVote {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  sportsbiteId  String   @map("sportsbite_id")
  option        Int      // 0 or 1
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, sportsbiteId])
  @@index([sportsbiteId])
  @@map("poll_votes")
}

// User notifications
model Notification {
  id                String   @id @default(uuid())
  recipientId       String?  @map("recipient_id")
  recipient         Profile? @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientUsername  String?  @map("recipient_username")
  type              String   // 'like' | 'comment' | 'reply' | 'follow' | 'mention' | 'system' | 'tip'
  title             String
  message           String
  sourceUserId      String?  @map("source_user_id")
  sourceUsername     String?  @map("source_username")
  data              Json?
  read              Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([recipientId, createdAt])
  @@index([recipientId, read])
  @@index([recipientUsername, createdAt])
  @@index([recipientUsername, read])
  @@map("soft_notifications")
}

// User-created communities
model Community {
  id             String    @id @default(uuid())
  slug           String    @unique
  name           String
  about          String    @default("")
  description    String    @default("")
  sportCategory  String    @default("general") @map("sport_category")
  type           String    @default("public") // 'public' | 'private' | 'invite-only'
  avatar         String?
  coverImage     String?   @map("cover_image")
  createdBy      String    @map("created_by")
  createdByHive  String?   @map("created_by_hive")
  memberCount    Int       @default(0) @map("member_count")
  postCount      Int       @default(0) @map("post_count")
  isVerified     Boolean   @default(false) @map("is_verified")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  members        CommunityMember[]

  @@index([sportCategory])
  @@index([memberCount])
  @@map("communities")
}

// Community membership
model CommunityMember {
  id            String    @id @default(uuid())
  communityId   String    @map("community_id")
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId        String    @map("user_id")
  user          Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  username      String
  hiveUsername   String?   @map("hive_username")
  role          String    @default("member") // 'admin' | 'moderator' | 'member'
  status        String    @default("active") // 'active' | 'pending' | 'banned'
  joinedAt      DateTime  @default(now()) @map("joined_at")
  invitedBy     String?   @map("invited_by")

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

// Community invites
model CommunityInvite {
  id              String    @id @default(uuid())
  communityId     String    @map("community_id")
  invitedEmail    String?   @map("invited_email")
  invitedHiveUser String?   @map("invited_hive_user")
  invitedBy       String    @map("invited_by")
  status          String    @default("pending") // 'pending' | 'accepted' | 'declined' | 'expired'
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")

  @@index([communityId])
  @@index([invitedEmail, status])
  @@index([invitedHiveUser, status])
  @@map("community_invites")
}

// Bookmarks
model Bookmark {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  postIdentifier  String   @map("post_identifier") // post ID or "author/permlink"
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, postIdentifier])
  @@map("bookmarks")
}

// Post drafts
model Draft {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  title         String    @default("")
  content       String    @default("")
  tags          String[]  @default([])
  sportCategory String?   @map("sport_category")
  featuredImage String?   @map("featured_image")
  communityId   String?   @map("community_id")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("drafts")
}

// Per-user settings (one-per-user)
model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

// Scheduled posts
model ScheduledPost {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  postData        Json     @map("post_data")
  scheduledAt     DateTime @map("scheduled_at")
  status          String   @default("pending") // 'pending' | 'published' | 'failed' | 'cancelled'
  publishedAt     DateTime? @map("published_at")
  publishedPostId String?  @map("published_post_id")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status, scheduledAt])
  @@map("scheduled_posts")
}

// Weekly post metrics
model PostMetric {
  id               String   @id @default(uuid())
  weekId           String   @map("week_id")
  postId           String   @map("post_id")
  author           String
  permlink         String
  views            Int      @default(0)
  uniqueViews      Int      @default(0) @map("unique_views")
  externalClicks   Int      @default(0) @map("external_clicks")
  votes            Int      @default(0)
  comments         Int      @default(0)
  shares           Int      @default(0)
  totalEngagement  Int      @default(0) @map("total_engagement")
  lastUpdated      DateTime @default(now()) @map("last_updated")

  @@unique([weekId, postId])
  @@index([weekId, author])
  @@map("post_metrics")
}

// Weekly user metrics
model UserMetric {
  id                  String   @id @default(uuid())
  weekId              String   @map("week_id")
  account             String
  period              String   @default("week")
  periodKey           String   @map("period_key")
  postsCreated        Int      @default(0) @map("posts_created")
  totalViews          Int      @default(0) @map("total_views")
  totalExternalClicks Int      @default(0) @map("total_external_clicks")
  totalVotesReceived  Int      @default(0) @map("total_votes_received")
  commentsReceived    Int      @default(0) @map("comments_received")
  commentsMade        Int      @default(0) @map("comments_made")
  totalEngagement     Int      @default(0) @map("total_engagement")
  lastUpdated         DateTime @default(now()) @map("last_updated")

  @@unique([weekId, account])
  @@map("user_metrics")
}

// Weekly leaderboard snapshots
model Leaderboard {
  id          String   @id @default(uuid())
  weekId      String   @unique @map("week_id")
  entries     Json     // Record<RewardCategory, LeaderboardEntry[]>
  generatedAt DateTime @default(now()) @map("generated_at")
  metadata    Json?    // postOfTheWeekSelectedBy, etc.

  @@map("leaderboards")
}

// Lifetime aggregated user stats (UserMetric is weekly-scoped, this is lifetime)
model UserStats {
  id                   String   @id @default(uuid())
  username             String   @unique
  totalPosts           Int      @default(0) @map("total_posts")
  totalSportsbites     Int      @default(0) @map("total_sportsbites")
  totalComments        Int      @default(0) @map("total_comments")
  totalViewsReceived   Int      @default(0) @map("total_views_received")
  totalTipsReceived    Decimal  @default(0) @map("total_tips_received") @db.Decimal(16, 6)
  totalMedalsEarned    Decimal  @default(0) @map("total_medals_earned") @db.Decimal(16, 6)
  memberSince          DateTime @default(now()) @map("member_since")
  lastActiveAt         DateTime @default(now()) @map("last_active_at")
  currentPostingStreak Int      @default(0) @map("current_posting_streak")
  longestPostingStreak Int      @default(0) @map("longest_posting_streak")
  lastPostWeek         String?  @map("last_post_week")
  medalsScore          Decimal  @default(0) @map("medals_score") @db.Decimal(10, 2)
  medalsRank           String?  @map("medals_rank")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @map("updated_at")

  @@index([totalPosts(sort: Desc)])
  @@index([lastActiveAt])
  @@map("user_stats")
}

// MEDALS tips on sportsbites
model Tip {
  id                String   @id @default(uuid())
  senderUsername    String   @map("sender_username")
  recipientUsername String   @map("recipient_username")
  amount            Decimal  @db.Decimal(16, 6)
  author            String
  permlink          String
  txId              String?  @map("tx_id")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([author, permlink])
  @@index([recipientUsername, createdAt])
  @@index([senderUsername])
  @@map("tips")
}

// Content reward distributions
model ContentReward {
  id        String   @id @default(uuid())
  weekId    String   @map("week_id")
  category  String   // RewardCategory
  winner    Json     // { account, postId, value }
  amount    Decimal  @db.Decimal(12, 3)
  status    String   @default("pending") // 'pending' | 'distributed' | 'failed'
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([weekId, category])
  @@map("content_rewards")
}

// ============================================================================
// Phase 3 — Prediction markets
// ============================================================================

enum PredictionStatus {
  OPEN
  LOCKED
  PENDING_APPROVAL
  SETTLING
  SETTLED
  VOID
  REFUNDED
}

model Prediction {
  id                String           @id @default(uuid())
  creatorUsername    String           @map("creator_username")
  title             String
  sportCategory     String?          @map("sport_category")
  matchReference    String?          @map("match_reference")
  locksAt           DateTime         @map("locks_at")
  status            PredictionStatus @default(OPEN)
  winningOutcomeId  String?          @map("winning_outcome_id")
  totalPool         Decimal          @default(0) @map("total_pool") @db.Decimal(12, 3)
  platformCut       Decimal          @default(0) @map("platform_cut") @db.Decimal(12, 3)
  burnedAmount      Decimal          @default(0) @map("burned_amount") @db.Decimal(12, 3)
  rewardPoolAmount  Decimal          @default(0) @map("reward_pool_amount") @db.Decimal(12, 3)
  feeTxId           String?          @map("fee_tx_id")
  feeBurnTxId       String?          @map("fee_burn_tx_id")
  feeRewardTxId     String?          @map("fee_reward_tx_id")
  hiveAuthor        String?          @map("hive_author")
  hivePermlink      String?          @map("hive_permlink")
  isVoid            Boolean          @default(false) @map("is_void")
  voidReason        String?          @map("void_reason")
  settledAt         DateTime?        @map("settled_at")
  settledBy         String?          @map("settled_by")
  proposedOutcomeId String?          @map("proposed_outcome_id")
  proposedBy        String?          @map("proposed_by")
  proposedAt        DateTime?        @map("proposed_at")
  proposedAction    String?          @map("proposed_action") // 'settle' or 'void'
  proposedVoidReason String?         @map("proposed_void_reason")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  commentCount      Int              @default(0) @map("comment_count")

  outcomes       PredictionOutcome[]  @relation("PredictionOutcomes")
  stakes         PredictionStake[]
  escrowLedger   PredictionEscrowLedger[]
  comments       PredictionComment[]
  winningOutcome PredictionOutcome?   @relation("WinningOutcome", fields: [winningOutcomeId], references: [id])

  @@index([status])
  @@index([creatorUsername])
  @@index([sportCategory])
  @@index([locksAt])
  @@index([matchReference])
  @@index([createdAt])
  @@map("predictions")
}

model PredictionOutcome {
  id            String   @id @default(uuid())
  predictionId  String   @map("prediction_id")
  label         String
  totalStaked   Decimal  @default(0) @map("total_staked") @db.Decimal(12, 3)
  backerCount   Int      @default(0) @map("backer_count")
  isWinner      Boolean  @default(false) @map("is_winner")
  createdAt     DateTime @default(now()) @map("created_at")

  prediction       Prediction        @relation("PredictionOutcomes", fields: [predictionId], references: [id], onDelete: Cascade)
  stakes           PredictionStake[]
  wonPredictions   Prediction[]      @relation("WinningOutcome")

  @@index([predictionId])
  @@map("prediction_outcomes")
}

model PredictionStake {
  id            String   @id @default(uuid())
  predictionId  String   @map("prediction_id")
  outcomeId     String   @map("outcome_id")
  username      String
  amount        Decimal  @db.Decimal(12, 3)
  payout        Decimal? @db.Decimal(12, 3)
  refundTxId    String?  @map("refund_tx_id")
  stakeTxId     String?  @unique @map("stake_tx_id")
  payoutTxId    String?  @map("payout_tx_id")
  createdAt     DateTime @default(now()) @map("created_at")

  prediction Prediction        @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  outcome    PredictionOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@index([predictionId, username, outcomeId])
  @@index([predictionId])
  @@index([username])
  @@map("prediction_stakes")
}

model PredictionEscrowLedger {
  id            String   @id @default(uuid())
  predictionId  String   @map("prediction_id")
  entryType     String   @map("entry_type")
  username      String?
  amount        Decimal  @db.Decimal(12, 3)
  txId          String?  @map("tx_id")
  createdAt     DateTime @default(now()) @map("created_at")

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([predictionId, txId])
  @@index([predictionId])
  @@map("prediction_escrow_ledger")
}

model PredictionComment {
  id              String    @id @default(uuid())
  predictionId    String    @map("prediction_id")
  username        String
  displayName     String?   @map("display_name")
  avatar          String?
  parentCommentId String?   @map("parent_comment_id")
  body            String
  createdAt       DateTime  @default(now()) @map("created_at")

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@index([predictionId, createdAt])
  @@index([parentCommentId])
  @@map("prediction_comments")
}

// ============================================================================
// Phase 4 — Badge system & MEDALS Rank
// ============================================================================

model UserBadge {
  id        String   @id @default(uuid())
  username  String
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")

  @@unique([username, badgeId])
  @@index([username])
  @@index([badgeId])
  @@map("user_badges")
}

model MonthlyLeaderboard {
  id          String   @id @default(uuid())
  monthId     String   @map("month_id")
  sportId     String   @map("sport_id") // '_overall' for combined, else sport slug
  entries     Json
  generatedAt DateTime @default(now()) @map("generated_at")

  @@unique([monthId, sportId])
  @@map("monthly_leaderboards")
}

model MonthlyTitle {
  id        String   @id @default(uuid())
  monthId   String   @map("month_id")
  sportId   String   @map("sport_id")
  username  String
  badgeId   String   @map("badge_id")
  score     Decimal  @db.Decimal(10, 2)
  awardedAt DateTime @default(now()) @map("awarded_at")

  @@unique([monthId, sportId])
  @@index([username])
  @@map("monthly_titles")
}

model UserSportStats {
  id            String   @id @default(uuid())
  username      String
  sportId       String   @map("sport_id")
  posts         Int      @default(0)
  sportsbites   Int      @default(0)
  comments      Int      @default(0)
  viewsReceived Int      @default(0) @map("views_received")
  medalsScore   Decimal  @default(0) @map("medals_score") @db.Decimal(10, 2)
  medalsRank    String?  @map("medals_rank")
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@unique([username, sportId])
  @@index([username])
  @@index([sportId])
  @@map("user_sport_stats")
}

// ============================================================================
// Phase 5 — Contest system
// ============================================================================

enum ContestStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  CALCULATING
  SETTLED
  CANCELLED
}

model Contest {
  id               String        @id @default(uuid())
  slug             String        @unique
  title            String
  description      String        @default("")
  contestType      String        @map("contest_type")
  status           ContestStatus @default(DRAFT)
  coverImage       String?       @map("cover_image")
  rules            String        @default("")

  entryFee         Decimal       @map("entry_fee") @db.Decimal(12, 3)
  maxEntries       Int?          @map("max_entries")

  platformFeePct   Decimal       @default(0.10) @map("platform_fee_pct") @db.Decimal(5, 4)
  creatorFeePct    Decimal       @default(0.10) @map("creator_fee_pct") @db.Decimal(5, 4)
  prizePool        Decimal       @default(0) @map("prize_pool") @db.Decimal(12, 3)
  prizeModel       String        @default("FEE_FUNDED") @map("prize_model")

  registrationOpens  DateTime    @map("registration_opens")
  registrationCloses DateTime    @map("registration_closes")
  startsAt           DateTime    @map("starts_at")
  endsAt             DateTime?   @map("ends_at")

  creatorUsername   String        @map("creator_username")
  settledAt        DateTime?     @map("settled_at")
  settledBy        String?       @map("settled_by")
  feeBurnTxId      String?       @map("fee_burn_tx_id")
  entryFeeBurnTxId String?       @map("entry_fee_burn_tx_id")

  typeConfig       Json?         @map("type_config")
  entryCount       Int           @default(0) @map("entry_count")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  entries          ContestEntry[]
  teams            ContestTeam[]
  matches          ContestMatch[]
  escrowLedger     ContestEscrowLedger[]
  interests        ContestInterest[]

  @@index([status])
  @@index([contestType])
  @@index([registrationCloses])
  @@map("contests")
}

model ContestInterest {
  id        String   @id @default(uuid())
  contestId String   @map("contest_id")
  username  String
  createdAt DateTime @default(now()) @map("created_at")

  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, username])
  @@index([contestId])
  @@map("contest_interests")
}

model ContestTeam {
  id          String   @id @default(uuid())
  contestId   String   @map("contest_id")
  name        String
  code        String
  pot         Int
  flagUrl     String?  @map("flag_url")
  groupLetter String?  @map("group_letter")
  eliminated  Boolean  @default(false)
  metadata    Json?

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, code])
  @@index([contestId, pot])
  @@map("contest_teams")
}

model ContestEntry {
  id             String   @id @default(uuid())
  contestId      String   @map("contest_id")
  username       String

  entryData      Json     @map("entry_data")

  totalScore     Decimal  @default(0) @map("total_score") @db.Decimal(12, 3)
  rank           Int?

  entryFeeTxId   String?  @unique @map("entry_fee_tx_id")
  payoutAmount   Decimal? @map("payout_amount") @db.Decimal(12, 3)
  payoutTxId     String?  @map("payout_tx_id")
  refundTxId     String?  @map("refund_tx_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, username])
  @@index([contestId, totalScore(sort: Desc)])
  @@index([username])
  @@map("contest_entries")
}

model ContestMatch {
  id              String    @id @default(uuid())
  contestId       String    @map("contest_id")

  matchNumber     Int       @map("match_number")
  round           String
  groupLetter     String?   @map("group_letter")

  homeTeamCode    String    @map("home_team_code")
  awayTeamCode    String    @map("away_team_code")

  homeScore       Int?      @map("home_score")
  awayScore       Int?      @map("away_score")

  scheduledAt     DateTime  @map("scheduled_at")
  resultEnteredAt DateTime? @map("result_entered_at")
  resultEnteredBy String?   @map("result_entered_by")

  contest         Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, matchNumber])
  @@index([contestId, round])
  @@index([contestId, homeTeamCode])
  @@index([contestId, awayTeamCode])
  @@map("contest_matches")
}

model ContestEscrowLedger {
  id        String   @id @default(uuid())
  contestId String   @map("contest_id")
  entryType String   @map("entry_type")
  username  String?
  amount    Decimal  @db.Decimal(12, 3)
  txId      String?  @map("tx_id")
  createdAt DateTime @default(now()) @map("created_at")

  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, txId])
  @@index([contestId])
  @@map("contest_escrow_ledger")
}

// ============================================================================
// Phase 6 — Last Man Standing
// ============================================================================

model LmsCompetition {
  id                   String    @id // e.g. 'lms-pl-2526-001'
  name                 String
  season               String
  status               String // open | picking | locked | results | complete
  currentGameweek      Int       @map("current_gameweek")
  startGameweek        Int       @map("start_gameweek")
  isFreeEntry          Boolean   @default(true) @map("is_free_entry")
  entryFeeMedals       Int       @default(0) @map("entry_fee_medals")
  prizeHive            Int       @default(200) @map("prize_hive")
  prizeMedals          Int       @default(5000) @map("prize_medals")
  platformCutPct       Int       @default(0) @map("platform_cut_pct")
  totalEntries         Int       @default(0) @map("total_entries")
  escrowAccount        String    @default("sp-predictions") @map("escrow_account")
  registrationDeadline DateTime? @map("registration_deadline")
  winnerUsername       String?   @map("winner_username")
  createdAt            DateTime  @default(now()) @map("created_at")
  completedAt          DateTime? @map("completed_at")

  entries   LmsEntry[]
  gameweeks LmsGameweek[]

  @@map("lms_competitions")
}

model LmsEntry {
  id                 Int       @id @default(autoincrement())
  competitionId      String    @map("competition_id")
  username           String
  status             String // alive | eliminated | winner
  usedTeams          String[]  @default([]) @map("used_teams")
  eliminatedGameweek Int?      @map("eliminated_gameweek")
  eliminatedByTeam   String?   @map("eliminated_by_team")
  joinedAt           DateTime  @default(now()) @map("joined_at")

  competition LmsCompetition @relation(fields: [competitionId], references: [id])
  picks       LmsPick[]

  @@unique([competitionId, username])
  @@index([competitionId, status])
  @@map("lms_entries")
}

model LmsPick {
  id            Int       @id @default(autoincrement())
  competitionId String    @map("competition_id")
  username      String
  gameweek      Int
  teamPicked    String    @map("team_picked")
  isAutoPick    Boolean   @default(false) @map("is_auto_pick")
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  result        String    @default("pending") // pending | survived | eliminated | postponed
  resolvedAt    DateTime? @map("resolved_at")
  resolvedBy    String?   @map("resolved_by")

  entry LmsEntry @relation(fields: [competitionId, username], references: [competitionId, username])

  @@unique([competitionId, username, gameweek])
  @@index([competitionId, gameweek])
  @@index([competitionId, username])
  @@index([competitionId, result])
  @@map("lms_picks")
}

model LmsGameweek {
  id              Int       @id @default(autoincrement())
  competitionId   String    @map("competition_id")
  gameweek        Int
  deadline        DateTime
  status          String // upcoming | picking | locked | complete
  survivorsCount  Int       @default(0) @map("survivors_count")
  eliminatedCount Int       @default(0) @map("eliminated_count")
  fixtures        Json      @default("[]")

  competition LmsCompetition @relation(fields: [competitionId], references: [id])

  @@unique([competitionId, gameweek])
  @@map("lms_gameweeks")
}

// ============================================================================
// Phase 7 — IPL Boundary Blackjack
// ============================================================================

model IplBbCompetition {
  id              String           @id @default(cuid())
  title           String
  season          String
  roundNumber     Int              @map("round_number")
  status          String           @default("open")  // open | active | complete
  dateFrom        DateTime         @map("date_from")
  dateTo          DateTime         @map("date_to")
  prizeFirst      Int              @default(2500) @map("prize_first")
  prizeSecond     Int              @default(1500) @map("prize_second")
  prizeThird      Int              @default(1000) @map("prize_third")
  totalMatches    Int              @default(0)    @map("total_matches")
  totalEntries    Int              @default(0)    @map("total_entries")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt      @map("updated_at")

  matches         IplBbMatch[]
  entries         IplBbEntry[]

  @@map("ipl_bb_competitions")
}

model IplBbMatch {
  id                 String           @id @default(cuid())
  competitionId      String           @map("competition_id")
  competition        IplBbCompetition @relation(fields: [competitionId], references: [id])
  matchNumber        Int              @map("match_number")
  cricketDataMatchId String?          @map("cricket_data_match_id")
  homeTeam           String           @map("home_team")
  awayTeam           String           @map("away_team")
  venue              String?
  kickoffTime        DateTime         @map("kickoff_time")
  status             String           @default("upcoming")  // upcoming | open | locked | resolved | abandoned

  actualBoundaries   Int?             @map("actual_boundaries")
  fours              Int?
  sixes              Int?
  resolvedAt         DateTime?        @map("resolved_at")
  resolvedBy         String?          @map("resolved_by")

  picks              IplBbPick[]

  @@index([competitionId])
  @@index([competitionId, status])
  @@map("ipl_bb_matches")
}

model IplBbEntry {
  id              String           @id @default(cuid())
  competitionId   String           @map("competition_id")
  competition     IplBbCompetition @relation(fields: [competitionId], references: [id])
  username        String
  totalPoints     Int              @default(0)  @map("total_points")
  bustCount       Int              @default(0)  @map("bust_count")
  hitCount        Int              @default(0)  @map("hit_count")
  submittedCount  Int              @default(0)  @map("submitted_count")
  finalRank       Int?             @map("final_rank")
  prizeAwarded    Int?             @map("prize_awarded")
  createdAt       DateTime         @default(now()) @map("created_at")

  picks           IplBbPick[]

  @@unique([competitionId, username])
  @@index([competitionId, totalPoints(sort: Desc)])
  @@map("ipl_bb_entries")
}

model IplBbPick {
  id               String       @id @default(cuid())
  competitionId    String       @map("competition_id")
  matchId          String       @map("match_id")
  match            IplBbMatch   @relation(fields: [matchId], references: [id])
  entryId          String       @map("entry_id")
  entry            IplBbEntry   @relation(fields: [entryId], references: [id])
  username         String

  guess            Int
  pointsScored     Int?         @map("points_scored")
  isBust           Boolean?     @map("is_bust")
  firstSubmittedAt DateTime     @default(now()) @map("first_submitted_at")
  updatedAt        DateTime     @updatedAt     @map("updated_at")

  @@unique([matchId, username])
  @@index([matchId])
  @@index([entryId])
  @@index([username])
  @@map("ipl_bb_picks")
}

// ============================================================================
// Curation System — Curator roster and curation tracking
// ============================================================================

// DB-backed curator management (replaces env-var-only approach)
model CuratorRoster {
  id        String   @id @default(uuid())
  username  String   @unique
  addedBy   String   @map("added_by")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([isActive])
  @@map("curator_roster")
}

// Records each curator's MEDALS curation on a post
model Curation {
  id                  String   @id @default(uuid())
  curatorUsername      String   @map("curator_username")
  author              String
  permlink            String
  amount              Decimal  @db.Decimal(12, 3)
  type                String   @default("post") // 'post' | 'sportsbite'
  source              String   @default("in_app") // 'in_app' | 'hive_comment' | 'auto_engagement'
  hiveCommentPermlink String?  @map("hive_comment_permlink")
  txId                String?  @map("tx_id")
  status              String   @default("pending") // 'pending' | 'completed' | 'failed'
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([curatorUsername, author, permlink])
  @@index([author, permlink])
  @@index([curatorUsername])
  @@index([createdAt])
  @@index([status])
  @@index([type])
  @@map("curations")
}
